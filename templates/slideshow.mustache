{{!
    @template mod_slideshow/slideshow

    @copyright 2024 Josemaria Bolanos <admin@mako.digital>

    IDs required for JS:
    * all

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * slides
}}

<div class="generalbox center clearfix">
    <ul id="slide-list" data-cmid="{{slideshow}}" class="mt-4">
        {{#slides}}
            <li class="slide-item no-swipe group" data-sortorder="{{sortorder}}" data-id="{{id}}">
                <div class="handle instant">{{index}}</div>
                <div class="name">{{name}}</div>
                <div class="actions">
                    <button title="{{#str}}delete, slideshow{{/str}}" class="delete btn btn-default">
                        {{#pix}} i/trash, core {{/pix}}
                    </button>
                    <button title="{{#str}}show, slideshow{{/str}}" class="show btn btn-default {{^hidden}}hidden{{/hidden}}">
                        {{#pix}} i/show, core {{/pix}}
                    </button>
                    <button title="{{#str}}hide, slideshow{{/str}}" class="hide btn btn-default {{#hidden}}hidden{{/hidden}}">
                        {{#pix}} i/hide, core {{/pix}}
                    </button>
                    <button title="{{#str}}edit, slideshow{{/str}}" class="edit btn btn-default">
                        {{#pix}} i/manual_item, core {{/pix}}
                    </a>
                </div>
            </li>
        {{/slides}}
    </ul>
</div>
